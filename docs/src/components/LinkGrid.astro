---
/**
 * Icon-led link grid for the "Start here" section. Each card has a
 * distinct strata-themed SVG glyph, a numeric counter, a title, and
 * a one-line summary. Hover: accent stripe sweeps in, icon shifts,
 * arrow nudges right.
 */

const links = [
  { n: '01', href: '/guide/getting-started/',     title: 'Getting started',     blurb: 'Install, init, first session, first save.',                  icon: 'flag' },
  { n: '02', href: '/guide/memory-architecture/', title: 'Memory architecture', blurb: 'Episodic / semantic / procedural and why it matters.',       icon: 'layers' },
  { n: '03', href: '/guide/concepts/',            title: 'Concepts',            blurb: 'Vault, scopes, branch awareness, the things to know.',       icon: 'compass' },
  { n: '04', href: '/guide/skills/',              title: 'Skills',              blurb: 'Every slash command and when each auto-invokes.',            icon: 'spark' },
  { n: '05', href: '/guide/bootstrap/',           title: 'Bootstrap',           blurb: 'One-time migration of existing planning docs into the vault.', icon: 'seed' },
  { n: '06', href: '/guide/code-graph/',          title: 'Code graph',          blurb: 'Graphify integration: code_map, drift, ADR linkage.',        icon: 'graph' },
  { n: '07', href: '/guide/correcting/',          title: 'Correcting the vault', blurb: 'Fix, invalidate, supersede, with full audit trail.',        icon: 'pen' },
  { n: '08', href: '/guide/mcp-tools/',           title: 'MCP tools',           blurb: 'The ambient surface plus the memory-recall subagent.',       icon: 'wire' },
  { n: '09', href: '/guide/architecture/',        title: 'Architecture',        blurb: 'How the pieces fit. The seam between skills, scripts, vault.', icon: 'core' },
];
---

<section class="link-grid">
  <p class="lg-eyebrow">documentation</p>
  <h2 class="lg-title">Start here.</h2>

  <div class="lg-cards">
    {links.map((l) => (
      <a class="lg-card" href={l.href}>
        <div class="lg-icon" aria-hidden="true">
          {l.icon === 'flag' && (
            <svg viewBox="0 0 32 32" fill="none">
              <path d="M8 4v24" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <path d="M8 5h16l-3 5 3 5H8" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
            </svg>
          )}
          {l.icon === 'layers' && (
            <svg viewBox="0 0 32 32" fill="none">
              <rect x="6" y="8"  width="20" height="3" rx="0.6" fill="currentColor" opacity="0.45"/>
              <rect x="6" y="14" width="20" height="3" rx="0.6" fill="currentColor" opacity="0.7"/>
              <rect x="6" y="20" width="20" height="3" rx="0.6" fill="currentColor" opacity="0.95"/>
            </svg>
          )}
          {l.icon === 'compass' && (
            <svg viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.4"/>
              <path d="M16 7 L19 16 L16 25 L13 16 Z" fill="currentColor" opacity="0.6"/>
              <circle cx="16" cy="16" r="1.4" fill="currentColor"/>
            </svg>
          )}
          {l.icon === 'spark' && (
            <svg viewBox="0 0 32 32" fill="none">
              <path d="M16 4v8 M16 20v8 M4 16h8 M20 16h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
            </svg>
          )}
          {l.icon === 'seed' && (
            <svg viewBox="0 0 32 32" fill="none">
              <path d="M16 26 V14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <path d="M16 14 C 12 11 9 12 7 16 C 11 17 14 16 16 14 Z" fill="currentColor" opacity="0.7"/>
              <path d="M16 14 C 20 11 23 12 25 16 C 21 17 18 16 16 14 Z" fill="currentColor" opacity="0.45"/>
              <path d="M10 28 H22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
            </svg>
          )}
          {l.icon === 'graph' && (
            <svg viewBox="0 0 32 32" fill="none">
              <circle cx="7"  cy="9"  r="2.2" fill="currentColor"/>
              <circle cx="25" cy="11" r="2.2" fill="currentColor" opacity="0.75"/>
              <circle cx="16" cy="22" r="2.2" fill="currentColor" opacity="0.55"/>
              <circle cx="6"  cy="24" r="2.2" fill="currentColor" opacity="0.7"/>
              <path d="M7 9 L16 22 M25 11 L16 22 M6 24 L16 22 M7 9 L25 11" stroke="currentColor" stroke-width="1" opacity="0.5"/>
            </svg>
          )}
          {l.icon === 'pen' && (
            <svg viewBox="0 0 32 32" fill="none">
              <path d="M5 27 L8 19 L22 5 L27 10 L13 24 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
              <path d="M19 8 L24 13" stroke="currentColor" stroke-width="1.4"/>
              <path d="M5 27 H14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.55"/>
            </svg>
          )}
          {l.icon === 'wire' && (
            <svg viewBox="0 0 32 32" fill="none">
              <rect x="4" y="8" width="9" height="6" rx="1.2" stroke="currentColor" stroke-width="1.3"/>
              <rect x="19" y="18" width="9" height="6" rx="1.2" stroke="currentColor" stroke-width="1.3"/>
              <path d="M13 11 H17 V21 H19" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <circle cx="17" cy="11" r="1.2" fill="currentColor"/>
              <circle cx="17" cy="21" r="1.2" fill="currentColor"/>
            </svg>
          )}
          {l.icon === 'core' && (
            <svg viewBox="0 0 32 32" fill="none">
              <defs><clipPath id="lg-core"><circle cx="16" cy="16" r="12"/></clipPath></defs>
              <g clip-path="url(#lg-core)" fill="currentColor">
                <rect x="0" y="4"  width="32" height="3.2" opacity="0.45"/>
                <rect x="0" y="9"  width="32" height="3.6" opacity="0.7"/>
                <rect x="0" y="14" width="32" height="3.2" opacity="0.95"/>
                <rect x="0" y="18" width="32" height="4"   opacity="0.75"/>
                <rect x="0" y="23" width="32" height="4"   opacity="0.55"/>
              </g>
              <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
          )}
        </div>
        <span class="lg-n">{l.n}</span>
        <h3 class="lg-card-title">{l.title}</h3>
        <p class="lg-blurb">{l.blurb}</p>
        <span class="lg-arrow">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .link-grid {
    margin: 6rem auto 5rem;
    max-width: 64rem;
  }

  .lg-eyebrow {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    margin: 0 0 1.25rem;
  }

  .lg-title {
    font-family: var(--strata-font-display);
    font-weight: 360;
    font-size: clamp(1.9rem, 3.8vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 2.5rem;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  .lg-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--sl-color-hairline);
  }

  @media (min-width: 700px) {
    .lg-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .lg-card {
    position: relative;
    display: block;
    padding: 2rem 1.5rem 2.25rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--sl-color-hairline);
    border-right: 0;
    overflow: hidden;
    transition: background-color 0.25s ease, transform 0.25s ease;
    isolation: isolate;
  }

  /* Diagonal accent sweep on hover */
  .lg-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--sl-color-accent) 14%, transparent) 0%,
      transparent 60%);
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: -1;
  }

  @media (min-width: 700px) {
    .lg-card {
      border-right: 1px solid var(--sl-color-hairline);
    }
    .lg-card:nth-child(3n) {
      border-right: 0;
    }
  }

  .lg-card:hover {
    background: transparent;
    border-bottom-color: var(--sl-color-accent);
  }
  .lg-card:hover::before { opacity: 1; }

  .lg-icon {
    color: var(--sl-color-accent);
    width: 2rem;
    height: 2rem;
    margin-bottom: 1rem;
    transition: transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .lg-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .lg-card:hover .lg-icon {
    transform: scale(1.1) rotate(-2deg);
  }

  .lg-card:hover .lg-n { color: var(--sl-color-accent); }
  .lg-card:hover .lg-arrow {
    transform: translateX(4px);
    color: var(--sl-color-accent);
  }

  .lg-n {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-4);
    margin-bottom: 0.5rem;
    display: block;
    transition: color 0.2s ease;
  }

  .lg-card-title {
    font-family: var(--strata-font-display);
    font-weight: 480;
    font-size: 1.18rem;
    margin: 0 0 0.5rem;
    color: var(--sl-color-text);
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 36;
  }

  .lg-blurb {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 18rem;
  }

  .lg-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    color: var(--sl-color-gray-4);
    font-size: 1rem;
    transition: transform 0.25s ease, color 0.25s ease;
  }
</style>
