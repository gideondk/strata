<script>
  // Play the conversation when the chat scrolls into view: user → thinking → claude.
  if ('IntersectionObserver' in window) {
    const chats = document.querySelectorAll<HTMLElement>('[data-chat]');
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const chat = e.target as HTMLElement;
          io.unobserve(chat);
          // Stage 1: user message visible.
          chat.classList.add('play-1');
          // Stage 2: thinking dots after a beat.
          setTimeout(() => {
            chat.classList.remove('play-1');
            chat.classList.add('play-2');
          }, 1100);
          // Stage 3: claude answer + citations.
          setTimeout(() => {
            chat.classList.remove('play-2');
            chat.classList.add('play-3');
          }, 2400);
        }
      },
      { threshold: 0.35 },
    );
    chats.forEach((c) => io.observe(c));
  } else {
    // No-IO fallback: just show the final state.
    document.querySelectorAll<HTMLElement>('[data-chat]').forEach((c) => c.classList.add('play-3'));
  }
</script>
