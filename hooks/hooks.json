{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-vault-read.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/prime-context.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/on-bash.py\""
          }
        ]
      },
      {
        "matcher": "mcp__.*recall",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/mark-recall-used.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/flush-on-compact.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/on-stop.py\""
          }
        ]
      }
    ]
  }
}

