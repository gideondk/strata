{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "enabledPlugins": [
    "strata@local"
  ],

  "pluginPaths": {
    "strata": ".claude/plugins/strata"
  },

  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ]
  }
}
