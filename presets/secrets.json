{
  "id": "secrets",
  "description": "Common credentials and tokens. Enabled by default.",
  "block": [
    { "name": "aws-access-key",      "regex": "\\bAKIA[0-9A-Z]{16}\\b" },
    { "name": "aws-secret-like",     "regex": "(?i)aws.{0,20}(secret|access).{0,20}['\"][A-Za-z0-9/+=]{32,}['\"]" },
    { "name": "github-pat",          "regex": "\\bghp_[A-Za-z0-9]{30,}\\b" },
    { "name": "github-oauth",        "regex": "\\bgho_[A-Za-z0-9]{30,}\\b" },
    { "name": "github-fine-grained", "regex": "\\bgithub_pat_[A-Za-z0-9_]{50,}\\b" },
    { "name": "slack-token",         "regex": "\\bxox[abprs]-[A-Za-z0-9-]{10,}\\b" },
    { "name": "jwt",                 "regex": "\\beyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\b" },
    { "name": "pem-private-key",     "regex": "BEGIN [A-Z ]*PRIVATE KEY" },
    { "name": "conn-string-pw",      "regex": "(?i)(password|pwd)\\s*=\\s*[^;\\s\"'<>]{6,}" },
    { "name": "azure-account-key",   "regex": "(?i)AccountKey\\s*=\\s*[A-Za-z0-9+/=]{40,}" },
    { "name": "gcp-service-account", "regex": "\"type\"\\s*:\\s*\"service_account\"" },
    { "name": "openai-key",          "regex": "\\bsk-(?:proj-|live-)?[A-Za-z0-9]{20,}\\b" },
    { "name": "anthropic-key",       "regex": "\\bsk-ant-[A-Za-z0-9_-]{50,}\\b" }
  ],
  "warn": []
}
